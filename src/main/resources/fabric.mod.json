{
  "schemaVersion": 1,
  "id": "twodimensionalreloaded",
  "version": "${version}",
  "name": "Two Dimensional: Reloaded",
  "description": "Turns Minecraft into a 2D side-scroller",
  "authors": ["amvern"],
  "contact": {
    "homepage": "https://github.com/amvern/Two-Dimensional-Reloaded",
    "sources": "https://github.com/amvern/Two-Dimensional-Reloaded",
    "issues": "https://github.com/amvern/Two-Dimensional-Reloaded/issues"
  },
  "license": "MIT",
  "icon": "assets/twodimensionalreloaded/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "github.amvern.twodimensionalreloaded.client.TwoDimensionalReloadedClient"
    ],
    "main": [
      "github.amvern.twodimensionalreloaded.TwoDimensionalReloaded"
    ],
    "modmenu": [
      "github.amvern.twodimensionalreloaded.client.config.ModMenuImpl"
    ]
  },
  "accessWidener": "twodimensionalreloaded.classtweaker",
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.modrinth": "https://modrinth.com/mod/two-dimensional-reloaded",
        "modmenu.curseforge": "https://www.curseforge.com/minecraft/mc-mods/two-dimensional-reloaded"
      }
    }
  },
  "mixins": [
    "twodimensionalreloaded.mixins.json",
    {
      "config": "twodimensionalreloaded.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=0.144.3+26.1",
    "minecraft": "${minecraft_version}",
    "sodium": ">=0.8.7+mc26.1",
    "cloth-config": ">=26.1.154+fabric"
  },
  "recommends": {
    "modmenu": "*"
  }
}